# Niqo Mobile (Expo) — copie en .env.local et remplace par tes valeurs
# Récupérables sur Supabase Dashboard → Settings → API
# Préfixe EXPO_PUBLIC_ obligatoire (sinon Expo n'expose pas la var au bundle).

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
