{
  "expo": {
    "name": "Niqo",
    "slug": "niqo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "niqo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.niqo.africa",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D85A30",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.niqo.africa",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Niqo a besoin d'accéder à tes photos pour publier tes annonces et choisir ton avatar.",
          "cameraPermission": "Niqo utilise la caméra pour photographier tes annonces, ton avatar et ta pièce d'identité (vérification du compte).",
          "microphonePermission": "Niqo n'enregistre pas de son. Cette autorisation est requise par le système pour activer la caméra."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Niqo utilise la caméra pour photographier tes annonces, ton avatar et ta pièce d'identité (vérification du compte).",
          "microphonePermission": "Niqo n'enregistre pas de son. Cette autorisation est requise par le système pour activer la caméra."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D85A30",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c45ee9d2-6ccb-47f9-8a21-bc5a48ffd5ed"
      }
    },
    "owner": "dominique358",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c45ee9d2-6ccb-47f9-8a21-bc5a48ffd5ed"
    }
  }
}
