# Tests intégration backend — copie ce fichier en `.env.test` et ajuste si besoin.
#
# Pour récupérer les valeurs locales : `supabase status` (CLI ≥ 1.224).
# Format des clés depuis fin 2024 : `sb_publishable_*` / `sb_secret_*`.
# Les valeurs ci-dessous sont des PLACEHOLDERS — remplace-les par la sortie
# de `supabase status` après avoir lancé `supabase start`.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<remplir-via-supabase-status-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<remplir-via-supabase-status-service-role-key>
