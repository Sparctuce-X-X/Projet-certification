# Niqo Edge Functions — secrets backend (Supabase secrets via `supabase secrets set`)
# JAMAIS committer la version remplie.

# OpenAI — modération texte (moderate-text, moderate-message)
OPENAI_API_KEY=<openai-api-key>

# AWS Rekognition — modération images (moderate-image)
AWS_ACCESS_KEY_ID=<aws-access-key>
AWS_SECRET_ACCESS_KEY=<aws-secret-key>
AWS_REGION=eu-west-1

# Clé service_role Supabase pour les Edge Functions internes
# (audit log admin, instrumentation crons, etc.)
NIQO_INTERNAL_KEY=<supabase-service-role-jwt>
