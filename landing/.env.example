# Niqo Admin Web (Next.js 16) — copie en .env.local
# Récupérables sur Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Resend (email transactionnel admin)
# Crée un compte sur https://resend.com (gratuit jusqu'à 100 emails/jour)
# Si la clé est absente, les actions admin marchent quand même (warning console).
RESEND_API_KEY=<resend-api-key>

# Sentry — public DSN, no-op si NODE_ENV !== "production".
NEXT_PUBLIC_SENTRY_DSN=<sentry-dsn>

# SENTRY_AUTH_TOKEN — privé, scope project:releases pour upload source maps.
# À set en Vercel → Environment Variables (Production uniquement).
# SENTRY_AUTH_TOKEN=<sentry-auth-token>
